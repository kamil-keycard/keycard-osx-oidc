<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.keycard.osx-oidcd</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/sbin/keycard-osx-oidcd</string>
        <string>--config</string>
        <string>/etc/keycard-osx-oidcd/config.toml</string>
    </array>

    <key>UserName</key>
    <string>root</string>
    <key>GroupName</key>
    <string>wheel</string>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>5</integer>

    <key>EnvironmentVariables</key>
    <dict>
        <key>RUST_LOG</key>
        <string>info</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/var/log/keycard-osx-oidcd.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/keycard-osx-oidcd.log</string>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
